# Base de donnees (MongoDB Atlas)
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
DB_NAME=silkroute

# Securite - genere une valeur aleatoire forte (ex: openssl rand -hex 32), ne jamais laisser vide
JWT_SECRET=

# Cloudinary (stockage documents KYC / images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe (optionnel pour le pilote - le paiement se fait manuellement via Mobile Money en phase 1)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# CORS - URL du frontend deploye (Vercel/Netlify), plusieurs URLs separees par des virgules
CORS_ORIGINS=https://ton-frontend.vercel.app
